---
import { site } from "../data/site";

interface Props {
  class?: string;
}

const className = Astro.props.class;
---

<div class:list={["inline-flex items-center gap-1.5 bg-gray-100 rounded-lg px-3 py-1.5 type-caption text-text-secondary leading-snug", className]}>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 text-text-muted" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
  </svg>
  <span set:html={site.contact.addressHtml} />
</div>
