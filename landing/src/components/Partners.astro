---
import { partners, advantages } from "../data/advantages";

const iconPaths: Record<string, string> = {
  package: `<path d="m3 7 9-4 9 4-9 4-9-4Z" /><path d="M3 7v10l9 4 9-4V7" /><path d="M12 11v10" />`,
  shield: `<path d="M12 3 5 6v6c0 5 3.4 8 7 9 3.6-1 7-4 7-9V6l-7-3Z" /><path d="m9 12 2 2 4-4" />`,
  cut: `<circle cx="6" cy="6" r="3" /><circle cx="6" cy="18" r="3" /><path d="M20 4 8.5 15.5" /><path d="m14 14 6 6" />`,
  warehouse: `<path d="m3 10 9-7 9 7" /><path d="M5 10v10h14V10" /><path d="M10 20v-6h4v6" />`,
  expert: `<circle cx="12" cy="8" r="3.5" /><path d="m9.8 11.2-1.2 8.3L12 17l3.4 2.5-1.2-8.3" /><path d="m12 6.8.7 1.4 1.6.2-1.2 1.1.3 1.6L12 10.3l-1.4.8.3-1.6-1.2-1.1 1.6-.2L12 6.8Z" />`,
};
---

<section class="py-6 md:py-8">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="type-h2 text-text-primary text-center mb-5 md:mb-6">
      Почему 3&nbsp;000+ клиентов заказывают кровлю у&nbsp;нас
    </h2>

    <!-- Карточки преимуществ -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3.5 mb-6">
      {advantages.map((item) => (
        <article
          class:list={[
            "rounded-xl border p-5 md:p-6 transition-all duration-200 ease-out active:translate-y-0 active:shadow-none",
            "hover:-translate-y-0.5 hover:shadow-[0_8px_18px_rgba(16,24,40,0.08)]",
            item.featured
              ? "border-primary/30 bg-primary/5 sm:col-span-2"
              : "border-gray-300 bg-white active:bg-gray-50",
          ]}
        >
          <div class="flex items-start gap-3">
            <div class="mt-0.5 h-8 w-8 shrink-0 rounded-full bg-primary/10 text-primary flex items-center justify-center">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={iconPaths[item.icon]} />
              </svg>
            </div>

            <div class="min-w-0">
              <p class="type-body-lg font-semibold text-text-primary mb-2 tracking-[-0.01em]">{item.title}</p>
              <p class="type-body text-text-secondary">{item.desc}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Логотипы партнёров -->
    <p class="type-caption text-text-muted text-center mb-3">Официальный дилер</p>
    <div class="flex flex-wrap items-center justify-center gap-4 md:gap-8">
      {partners.map((p) => (
        <div class="w-[calc(50%-8px)] sm:w-[170px] flex items-center justify-center">
          <img
            src={typeof p.logo === 'string' ? p.logo : p.logo.src}
            alt={p.name}
            class="max-w-full max-h-14 object-contain"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
