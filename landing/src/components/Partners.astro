---
const logos = Array.from({ length: 9 }, (_, i) => i + 1);

const advantages = [
  {
    title: "Всё в\u00A0одном заказе",
    desc: "Черепица, водосток, мембрана и\u00A0крепёж в\u00A0одном договоре и\u00A0с\u00A0одной ответственностью.",
    icon: "package",
    featured: true,
    badge: "Топ-преимущество",
  },
  {
    title: "Фиксация цены",
    desc: "Закрепляем стоимость на\u00A0момент расчёта, чтобы инфляция не\u00A0увеличила смету.",
    icon: "shield",
  },
  {
    title: "Точный раскрой",
    desc: "Считаем листы и\u00A0доборные элементы под ваш проект без лишних остатков.",
    icon: "cut",
  },
  {
    title: "Готовые комплекты на\u00A0складе",
    desc: "Основные позиции держим в\u00A0наличии, чтобы вы не\u00A0ждали долгую поставку.",
    icon: "warehouse",
  },
  {
    title: "Экспертная комплектация с\u00A02008\u00A0года",
    desc: "Подбираем совместимые материалы и\u00A0узлы, чтобы кровля служила дольше.",
    icon: "expert",
  },
];
---

<section class="py-6 md:py-8">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="type-h2 text-text-primary text-center mb-5 md:mb-6">
      Почему 3&nbsp;000+ клиентов заказывают кровлю у&nbsp;нас
    </h2>

    <!-- Карточки преимуществ -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3.5 mb-6">
      {advantages.map((item) => (
        <article
          class:list={[
            "rounded-xl border p-5 md:p-6 transition-all duration-200 ease-out active:translate-y-0 active:shadow-none",
            "hover:-translate-y-0.5 hover:shadow-[0_8px_18px_rgba(16,24,40,0.08)]",
            item.featured
              ? "border-primary/30 bg-primary/5 sm:col-span-2"
              : "border-gray-300 bg-white active:bg-gray-50",
          ]}
        >
          <div class="flex items-start gap-3">
            <div class="mt-0.5 h-8 w-8 shrink-0 rounded-full bg-primary/10 text-primary flex items-center justify-center">
              {item.icon === "package" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m3 7 9-4 9 4-9 4-9-4Z" />
                  <path d="M3 7v10l9 4 9-4V7" />
                  <path d="M12 11v10" />
                </svg>
              )}
              {item.icon === "shield" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3 5 6v6c0 5 3.4 8 7 9 3.6-1 7-4 7-9V6l-7-3Z" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              )}
              {item.icon === "cut" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="6" cy="6" r="3" />
                  <circle cx="6" cy="18" r="3" />
                  <path d="M20 4 8.5 15.5" />
                  <path d="m14 14 6 6" />
                </svg>
              )}
              {item.icon === "warehouse" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m3 10 9-7 9 7" />
                  <path d="M5 10v10h14V10" />
                  <path d="M10 20v-6h4v6" />
                </svg>
              )}
              {item.icon === "expert" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="8" r="4" />
                  <path d="M4 21a8 8 0 0 1 16 0" />
                  <path d="m17 13 2 2 3-3" />
                </svg>
              )}
            </div>

            <div class="min-w-0">
              {item.badge && (
                <p class="mb-1 inline-flex rounded-full bg-primary/15 px-2 py-0.5 type-caption font-medium leading-none text-primary">
                  {item.badge}
                </p>
              )}
              <p class="type-h3 text-text-primary mb-2 tracking-[-0.01em]">{item.title}</p>
              <p class="type-body text-text-secondary">{item.desc}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Логотипы партнёров -->
    <p class="type-caption text-text-muted text-center mb-3">Официальный дилер</p>
    <div class="flex flex-wrap justify-center gap-3">
      {logos.map((n) => (
        <div class="w-[calc(50%-6px)] sm:w-[calc(33.333%-8px)] md:w-[calc(25%-9px)] lg:w-[calc(20%-10px)] max-w-[160px] bg-white rounded-sm aspect-video flex items-center justify-center text-text-muted type-caption border border-gray-300">
          {n}
        </div>
      ))}
    </div>
  </div>
</section>
