---
const logos = Array.from({ length: 9 }, (_, i) => i + 1);
---

<section class="py-4 md:py-6">
  <div class="max-w-7xl mx-auto px-4">
    <p class="text-xs text-text-muted text-center mb-3">Наши партнёры</p>
    <div class="flex flex-wrap justify-center gap-3">
      {logos.map((n) => (
        <div class="w-[calc(50%-6px)] sm:w-[calc(33.333%-8px)] md:w-[calc(25%-9px)] lg:w-[calc(20%-10px)] max-w-[160px] bg-white rounded-sm aspect-video flex items-center justify-center text-text-muted text-xs border border-gray-300">
          {n}
        </div>
      ))}
    </div>
  </div>
</section>
