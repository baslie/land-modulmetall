---
import logo from "../assets/ebis-logo.svg";
import { site } from "../data/site";
---

<header class="bg-white">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-14">
    <a href="/" class="flex items-center gap-2">
      <img src={logo.src} alt="ЭБИС" class="h-9 w-auto" />
      <span class="type-caption text-xs sm:text-[0.8125rem] text-text-secondary bg-gray-100 rounded px-1.5 py-0.5 whitespace-nowrap shrink-0">Работаем<br class="sm:hidden" />с&nbsp;2008&nbsp;года</span>
    </a>
    <div class="flex items-center gap-4">
      <div class="hidden lg:inline-flex items-baseline gap-1.5 bg-gray-100 rounded-lg px-3 py-1.5 type-caption text-text-secondary leading-snug">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 text-text-muted translate-y-[1px]" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
        </svg>
        <span class="text-right">
          ул.&nbsp;Калининградская,&nbsp;2Е, Большое&nbsp;Исаково,<br />Калининградская&nbsp;обл.
        </span>
      </div>
      <a
        href={site.contact.phoneHref}
        class="border border-text-primary rounded-btn text-text-primary type-caption font-medium px-4 py-1.5 hover:border-primary hover:text-primary transition-colors duration-300"
      >
        {site.contact.phone}
      </a>
    </div>
  </div>
</header>
