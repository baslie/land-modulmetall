---
import { site } from "../data/site";
---

<section class="py-4 md:py-6">
  <div class="max-w-5xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-[360px_1fr] gap-6 lg:gap-8 items-stretch">
    <!-- Boomstream vertical video -->
    <div class="w-full max-w-[360px] mx-auto lg:mx-0">
      <div class="aspect-[9/16] rounded-lg overflow-hidden bg-gray-200">
        <script src="https://play.boomstream.com/A4neJYiB/config.jsonp?title=0&autoplay=1" async></script>
        <script src="https://play.boomstream.com/assets/javascripts/biframesdk.js?v=1.1.1" async></script>
        <span
          data-boomstream-code="A4neJYiB"
          data-boomstream-mode="adaptive"
          data-boomstream-use-fullscreen-mode="0"
        ></span>
      </div>
    </div>

    <!-- Lead form card -->
    <div class="border-[5px] border-primary rounded-lg p-6 h-full flex flex-col">
      <h2 class="type-h2 text-text-primary mb-1 text-center">
        Рассчитайте стоимость вашей крыши за&nbsp;15&nbsp;минут
      </h2>
      <p class="type-caption text-text-secondary mb-3 text-center">
        Оставьте контакты&nbsp;&mdash; посчитаем комплект и&nbsp;пришлём раскладку. Цены зафиксируем на&nbsp;<span class="underline decoration-current underline-offset-2" set:html={site.promo.dateLabelHtml} />, а&nbsp;дальше решите сами.
      </p>
      <form id="lead-form" action="#" method="POST" class="space-y-3 flex-1 flex flex-col" data-phone={site.contact.phone}>
        <input
          type="text"
          id="lead-name"
          name="name"
          placeholder="Имя"
          aria-label="Имя"
          class="form-field h-[44px]"
        />
        <input
          type="tel"
          id="lead-phone"
          name="phone"
          placeholder="Телефон"
          aria-label="Телефон"
          required
          class="form-field h-[44px]"
        />
        <textarea
          id="lead-comment"
          name="comment"
          placeholder="Комментарий"
          aria-label="Комментарий"
          rows="2"
          class="form-field min-h-[80px] py-3 resize-y flex-1"
        ></textarea>
        <label class="flex items-start gap-2 cursor-pointer type-caption text-text-secondary leading-snug">
          <input
            type="checkbox"
            name="consent"
            required
            class="mt-0.5 shrink-0 accent-primary w-5 h-5 cursor-pointer"
          />
          <span>
            Я&nbsp;подтверждаю ознакомление с&nbsp;условиями
            <a href="/privacy" target="_blank" rel="noopener noreferrer" class="underline hover:no-underline">Согласия на&nbsp;обработку персональных данных</a>
            пользователя сайта и&nbsp;даю согласие на&nbsp;обработку моих персональных данных на&nbsp;указанных в&nbsp;нем порядке и&nbsp;условиях.
          </span>
        </label>
        <p id="lead-error" class="text-red-600 type-caption text-center mt-2 hidden"></p>
        <div class="flex flex-col items-center mt-auto">
          <button
            type="submit"
            class="lead-submit h-[48px] px-12 bg-primary text-white type-body font-semibold rounded-btn-lg hover:bg-primary-hover transition-colors duration-300 cursor-pointer"
          >
            Получить расчёт
          </button>
          <p class="mt-2 type-caption text-primary font-semibold inline-flex items-center justify-center gap-1">
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="M9 16h5"/><path d="M9 12h5a2 2 0 1 0 0-4h-3v9"/>
            </svg>
            Экономия до&nbsp;52&nbsp;500&nbsp;₽ с&nbsp;одной крыши
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

<script src="../scripts/lead-form.ts"></script>
